generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  passwordHash  String?
  name          String?
  phone         String?
  
  // Gamification
  xp            Int       @default(0)
  streak        Int       @default(0)
  longestStreak Int       @default(0)
  lastActiveAt  DateTime?
  
  // Plan
  plan          String    @default("free")
  planExpiresAt DateTime?
  isPremium     Boolean   @default(false)
  
  // Pricing
  offeredPrice  Int?
  subscriptionExpiresAt DateTime?
  
  // Daily goal
  dailyGoal     Int       @default(15)
  
  // Personalization from subtopic feedback
  lastExperienceLevel String?
  lastPreferences     String[]
  lastAccuracy        Int       @default(0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  attempts      Attempt[]
  practiceModeAttempts PracticeModeAttempt[]
  userBadges    UserBadge[]
  dailyStats    DailyStats?
  
  @@index([email])
  @@index([lastActiveAt])
}

model Chapter {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  icon         String
  order        Int
  recommended  Boolean  @default(false)
  totalTopics  Int
  isActive     Boolean  @default(true)
  
  topics       Topic[]
  chapterProgress ChapterProgress[]
  
  @@index([order])
}

model Topic {
  id            String   @id @default(cuid())
  chapterId     String
  slug          String   @unique
  name          String
  order         Int
  questionCount Int
  level         String   // pass, average, expert
  emoji         String
  label         String
  range         String
  locked        Boolean  @default(false)
  isActive      Boolean  @default(true)
  
  chapter       Chapter  @relation(fields: [chapterId], references: [id])
  questions     Question[]
  attempts      Attempt[]
  topicProgress TopicProgress[]
  mistakes      Mistake[]
  
  @@index([chapterId, order])
  @@index([level])
}

model Question {
  id            String   @id @default(cuid())
  topicId       String
  chapterId     String
  level         String
  
  text          String
  option1       String
  option2       String
  option3       String
  option4       String
  correctIndex  Int
  explanation   String
  
  subtopicTag   String
  difficulty    Int      @default(1)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  
  topic         Topic    @relation(fields: [topicId], references: [id])
  questionModes QuestionMode[]
  
  @@index([topicId, level, isActive])
  @@index([subtopicTag])
}

model Attempt {
  id            String   @id @default(cuid())
  userId        String
  topicId       String
  chapterId     String
  level         String
  
  score         Int
  total         Int
  mastery       Int
  xpEarned      Int      @default(0)
  timeTakenSecs Int
  
  weakSubtopics String[]
  completedAt   DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id])
  topic         Topic    @relation(fields: [topicId], references: [id])
  answers       Answer[]
  
  @@index([userId, completedAt])
  @@index([userId, topicId])
}

model Answer {
  id            String   @id @default(cuid())
  attemptId     String
  
  selectedIndex Int
  correctIndex  Int
  isCorrect     Boolean
  timeTakenSecs Int
  subtopicTag   String
  
  attempt       Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  
  @@index([attemptId])
}

model DailyStats {
  id              String   @id @default(cuid())
  userId          String   @unique
  
  streak          Int      @default(0)
  longestStreak   Int      @default(0)
  xp              Int      @default(0)
  dailyGoal       Int      @default(15)
  
  todayDate       String   @default("")
  todayQuestionsAnswered Int @default(0)
  todayQuestionsCorrect  Int @default(0)
  todayGoalHit    Boolean  @default(false)
  
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
}

model TopicProgress {
  id            String   @id @default(cuid())
  userId        String
  topicId       String
  
  bestScore     Int      @default(0)
  mastery       Int      @default(0)
  attempts      Int      @default(0)
  completedAt   DateTime?
  lastDoneAt    DateTime?
  
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  
  @@unique([userId, topicId])
  @@index([userId])
}

model Mistake {
  id            String   @id @default(cuid())
  userId        String
  topicId       String
  subtopicTag   String
  wrongCount    Int      @default(0)
  
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  
  @@unique([userId, topicId, subtopicTag])
  @@index([userId])
}

model ChapterProgress {
  id               String   @id @default(cuid())
  userId           String
  chapterId        String
  completedTopicIds String[]
  pct              Int      @default(0)
  lastPractisedAt  DateTime?
  
  chapter          Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  
  @@unique([userId, chapterId])
  @@index([userId])
}

model PracticeMode {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  tag         String
  color       String
  isPro       Boolean  @default(false)
  isActive    Boolean  @default(true)
  order       Int
  
  questionModes QuestionMode[]
  attempts     PracticeModeAttempt[]
  
  @@index([order])
  @@index([isActive])
}

model QuestionMode {
  id             String   @id @default(cuid())
  questionId     String
  practiceModeId String
  year           Int?
  examBoard      String?
  
  question       Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  practiceMode   PracticeMode @relation(fields: [practiceModeId], references: [id], onDelete: Cascade)
  
  @@unique([questionId, practiceModeId])
  @@index([practiceModeId])
}

model PracticeModeAttempt {
  id             String   @id @default(cuid())
  userId         String
  practiceModeId String
  
  score          Int
  total          Int
  mastery        Int
  xpEarned       Int
  timeTakenSecs  Int
  
  completedAt    DateTime @default(now())
  
  user           User        @relation(fields: [userId], references: [id])
  practiceMode   PracticeMode @relation(fields: [practiceModeId], references: [id])
  answers        PracticeModeAnswer[]
  
  @@index([userId, completedAt])
  @@index([userId, practiceModeId])
}

model PracticeModeAnswer {
  id             String   @id @default(cuid())
  attemptId      String
  
  selectedIndex  Int
  correctIndex   Int
  isCorrect      Boolean
  timeTakenSecs  Int
  subtopicTag    String
  
  attempt        PracticeModeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  
  @@index([attemptId])
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  type        String   // streak, xp, accuracy, session, mode, comeback
  criteria    Json     // JSON criteria for unlocking
  order       Int
  isActive    Boolean  @default(true)
  
  userBadges  UserBadge[]
  
  @@index([order])
  @@index([isActive])
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  earnedAt   DateTime @default(now())
  revealedAt DateTime?
  isRevealed Boolean  @default(false)
  progress   Int      @default(0)
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  
  @@unique([userId, badgeId])
  @@index([userId])
}

model PricingStats {
  id              Int      @id @default(1)
  totalPaidUsers  Int      @default(0)
  
  @@unique([id])
}

model SubtopicFeedback {
  id              String   @id @default(cuid())
  userId          String
  subtopicTag     String
  experienceLevel String
  preferences     String[]
  accuracy        Int
  totalQuestions  Int
  nextLevel       String
  nextSubtopic    String
  message         String
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([subtopicTag])
  @@index([createdAt])
}

// Stores message history for dynamic message system
// Prevents repetition of the same messages across sessions
model UserMessageHistory {
  id           String   @id @default(cuid())
  userId       String
  lastMessages String[] // Store last 3 messages shown
  updatedAt    DateTime @updatedAt

  @@index([userId])
}
